# --- Stripe (use sandbox keys from team vault; never commit real keys) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Used for Checkout success/cancel redirects (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Price IDs from Stripe Dashboard (see docs/STRIPE_CLIENT_HANDOFF.md)
# Starter: $8.99/mo · $47.99/yr regular · $35.99/yr exit promo
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_STARTER_EXIT_ANNUAL=
STRIPE_PRICE_FAMILY_ANNUAL=
STRIPE_PRICE_POWER_ANNUAL=

# --- PostHog ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Sentry (npx @sentry/wizard@latest -i nextjs) ---
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
NEXT_PUBLIC_SENTRY_DSN=

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=
# Optional: new-format keys from dashboard (if required by your SDK)
SUPABASE_SECRET_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# sbp_... — personal access token (Management API / CLI). Not used by supabase-js for DB queries; use SERVICE_ROLE for server DB access.
SUPABASE_ACCESS_TOKEN=

