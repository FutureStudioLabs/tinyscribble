# Cloudflare R2 Storage (use your own values — never commit real secrets)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com

# --- APIYI (image + video) — SERVER ONLY, no NEXT_PUBLIC_ ---
# https://docs.apiyi.com/en · full spec: docs/APIYI_INTEGRATION_BRIEF.md
APIYI_API_KEY=
APIYI_BASE_URL=https://api.apiyi.com
# Use nano-banana only (not nano-banana-2 / pro) unless product explicitly changes
APIYI_IMAGE_MODEL=nano-banana
APIYI_VIDEO_MODEL=veo-3.1-fast-fl

# --- Stripe (use sandbox keys from team vault; never commit real keys) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Canonical public URL (no trailing slash). Local dev default below; on Vercel Production set e.g.
# https://tinyscribble.vercel.app or your custom domain so Stripe / magic links never use a preview hostname.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Price IDs from Stripe Dashboard (see docs/STRIPE_CLIENT_HANDOFF.md)
# Starter display copy for paywall / Skip Trial: see `src/constants/starter-plan-display.ts`
# Starter: $8.99/mo · $47.99/yr regular · $35.99/yr exit promo
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_STARTER_EXIT_ANNUAL=
STRIPE_PRICE_FAMILY_ANNUAL=
STRIPE_PRICE_POWER_ANNUAL=

# --- PostHog ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Sentry (npx @sentry/wizard@latest -i nextjs) ---
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
NEXT_PUBLIC_SENTRY_DSN=

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Optional: OTP bypass for dev/testing — when email+code match, sign in without real OTP
# OTP_BYPASS_EMAIL=you@example.com
# OTP_BYPASS_CODE=123456
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=
# Optional: new-format keys from dashboard (if required by your SDK)
SUPABASE_SECRET_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# sbp_... — personal access token (Management API / CLI). Not used by supabase-js for DB queries; use SERVICE_ROLE for server DB access.
SUPABASE_ACCESS_TOKEN=

# --- Resend (when wired) ---
# RESEND_API_KEY=
